# Production Environment Variables Template
# Copy this file to .env.local for development or configure these in your deployment platform
# NEVER commit actual secrets to version control

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# APPLICATION CONFIGURATION (REQUIRED)
# =============================================================================
# Your application URL (used for redirects and email templates)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Environment (production, staging, development)
NODE_ENV=production

# =============================================================================
# CLOUDINARY CONFIGURATION (REQUIRED FOR IMAGE UPLOADS)
# =============================================================================
# Get these from your Cloudinary dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =============================================================================
# EMAIL CONFIGURATION (REQUIRED FOR NOTIFICATIONS)
# =============================================================================
# SMTP settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Your App Name

# =============================================================================
# WEBHOOK CONFIGURATION (OPTIONAL)
# =============================================================================
# Make.com webhook for automation (optional)
NEXT_PUBLIC_MAKE_WEBHOOK_URL=your_make_webhook_url

# =============================================================================
# PUSH NOTIFICATIONS (OPTIONAL)
# =============================================================================
# OneSignal configuration for push notifications
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# =============================================================================
# SECURITY SETTINGS (PRODUCTION)
# =============================================================================
# Authentication bypass (NEVER set to true in production)
NEXT_PUBLIC_BYPASS_AUTH=false
