{
  "name": "villa-property-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:turbo": "next dev --turbopack --port 3000",
    "build": "next build",
    "build:production": "NODE_ENV=production next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "start:production": "NODE_ENV=production next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out node_modules/.cache",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:migrate": "supabase db push",
    "supabase:setup": "chmod +x scripts/deploy-functions.sh && ./scripts/deploy-functions.sh",
    "supabase:functions": "supabase functions deploy",
    "supabase:logs": "supabase functions logs",
    "setup:database": "node scripts/setup-database.js",
    "create:notifications": "node scripts/create-notification-tables.js",
    "create:notifications-table": "node scripts/create-notifications-table.js",
    "db:seed": "supabase db reset --db-url postgresql://postgres:postgres@localhost:54322/postgres",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "dev:debug": "cross-env NODE_OPTIONS='--inspect' next dev"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.3",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.4.6",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.23.0",
    "html2canvas": "^1.4.1",
    "ical": "^0.8.0",
    "jspdf": "^2.5.2",
    "lenis": "^1.3.4",
    "lucide-react": "^0.525.0",
    "next": "15.3.4",
    "next-cloudinary": "^6.16.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.4",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-hot-toast": "^2.4.1",
    "react-onesignal": "^3.0.1",
    "recharts": "^3.0.2",
    "supabase": "^2.30.4",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.0.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
